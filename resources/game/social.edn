{:contract/id :kotoba.game/social
 :contract/version 15
 :runtime :cljc
 :capabilities
 {:identity {:key :player/did}
  :cross-game-profile {:fields #{:display-name :bio :avatar :visibility :equipped-title}
                       :title-admission :achievement-unlock}
  :achievements {:source :host-verified-event
                 :reducers #{:sum :max}
                 :idempotency :event/id
                 :unlock :immutable}
  :activity {:append-only true :idempotency :activity/id
             :visibility #{:public :friends :private}}
  :notifications {:kinds #{:achievement :friend-request :party-invite :group :match
                           :mail :purchase :payment :ranking :guild-event :system}
                  :idempotency :notification/id
                  :source-link :notification/source-id
                  :inbox {:ordering [:unread :newest :id]
                          :max-page-size 100}
                  :lifecycle #{:unread :read :dismissed :expired}
                  :recipient-only true}
  :save {:concurrency :optimistic-revision}
  :wallet {:currencies #{:free-gem :paid-gem}
           :idempotency :tx/id
           :negative-balance false}
  :inventory {:models #{:quantity :entitlement}}
  :subscription {:namespace game.subscription
                 :access-statuses #{:active :grace}
                 :events #{:started :renewed :canceled :payment-failed :recovered
                           :refunded :revoked}
                 :entitlement-source :verified-provider-event}
  :store {:atomic [:wallet/debit :inventory/grant :receipt/write]
          :idempotency :receipt/id}
  :commerce {:gem-pack {:wallet-currency :paid-gem :fiat-unit :minor}
             :payment #{:pending :settled :refunded}
             :settlement {:verified true :idempotent true}
             :refund {:full true :spent-balance :manual-review}}
  :daily-reward {:clock :host-verified-utc-day
                 :currency :free-gem
                 :idempotency [:player :day]
                 :streak {:missed-day :restart :schedule :cyclic}}
  :mail {:attachments #{:free-gem :stack-item}
         :claim {:recipient-only true :idempotent true}
         :gift {:relationship :verified-friend
                :escrow :send-time
                :max-free-gem 100
                :paid-gem false
                :entitlement false
                :expiry-refund true}}
  :matchmaking {:partition [:game :mode :region]
                :ordering [:joined-at :player]
                :rating-window true
                :party {:invite #{:pending :accepted :declined :expired}
                        :queue-snapshot true :leader-only true :ready-check :all-members}
                :lifecycle #{:queued :ready :active :declined :expired :complete}
                :ready-check {:accept :all :decline :requeue-other :timeout true}
                :reconnect {:grace-window :host-clock :resume true}
                :leave-penalty {:scope :player :queue-cooldown true}}
  :guild-events {:partition [:event/game :event/id]
                 :admission [:event/active :gameplay/verified :guild-membership/verified]
                 :contribution {:positive true :idempotency :submission/id}
                 :ranking {:entity :guild :ties :competition-rank}
                 :rewards {:eligible :verified-contributors
                           :currency :free-gem :payout :idempotent}}
  :ranking {:partition [:board/game :board/season]
            :admission [:season/active :score/verified]
            :ties :competition-rank
            :display-tie-break [:score/at :score/player]
            :close {:snapshot true :reward-tiers true}}
  :social-graph {:friend-request [:pending :accepted :declined]
                 :block {:directional true :removes-friendship true}}
  :groups {:kinds #{:party :guild}
           :roles #{:owner :moderator :member}
           :lifecycle #{:join :leave :remove-member :change-role :transfer-owner}
           :capacity true}
  :chat {:rooms #{:direct :party :guild :game}
         :admission [:membership :block :length :moderation :duplicate]
         :history :bounded}
  :platform-hud {:projection :platform-hud-model
                 :tabs [:notifications :profile :wallet :inventory :store :saves :missions :battle-pass :membership :mail :match
                        :guild-events :friends :groups]
                 :provider-neutral true}}
 :host-responsibilities
 #{:persistence :clock :identity-proof :score-verification
   :payment-verification :content-moderation :transport}}
