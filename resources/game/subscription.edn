{:contract/id :kotoba.game/subscription
 :contract/version 1
 :provider-events #{:started :renewed :canceled :payment-failed :recovered :refunded :revoked}
 :access-statuses #{:active :grace}
 :identity [:player :plan :provider-ref]
 :invariants {:event-idempotency :subscription-event/id
              :provider-ref-owner [:player :plan]
              :ordering :occurred-at-monotonic
              :clock :trusted-host
              :cancel :access-through-period-end
              :refund :immediate-revocation
              :chargeback :immediate-revocation
              :grace :plan-bounded}
 :host-responsibilities #{:provider-signature-verification :receipt-verification
                          :durable-event-ledger :entitlement-materialization
                          :webhook-retry :tax :regional-pricing}}
