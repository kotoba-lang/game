{:contract/id :kotoba.game/analytics
 :contract/version 1
 :namespace game.analytics
 :event {:identity :event/id
         :ordering [:event/occurred-at :event/id]
         :idempotency :event/id
         :privacy #{:essential :functional :analytics}
         :trust #{:client :server :payment-provider}
         :dimensions {:max 16 :string-max 96
                      :forbidden #{:email :phone :ip :ip-address :user-agent
                                   :device-fingerprint :name :latitude :longitude :address}}}
 :session {:inactivity-seconds 1800 :clock :host-authoritative}
 :metrics {:activity #{:dau :wau :mau :sessions}
           :retention #{:d1 :d7 :d30}
           :funnel #{:conversion :dropoff}
           :dimensions #{:game :version :channel :platform :campaign}
           :revenue #{:gross-minor :payer-count :arpdau-minor :arppu-minor}}
 :money {:unit :minor :group-by :currency :client-authoritative false}
 :host-responsibilities #{:identity-proof :pseudonymization :durable-persistence
                          :authoritative-clock :consent :event-verification
                          :currency-conversion :retention-policy :data-deletion}}

