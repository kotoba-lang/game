{:contract/id :kotoba.game/social
 :contract/version 2
 :runtime :cljc
 :capabilities
 {:identity {:key :player/did}
  :save {:concurrency :optimistic-revision}
  :wallet {:currencies #{:free-gem :paid-gem}
           :idempotency :tx/id
           :negative-balance false}
  :inventory {:models #{:quantity :entitlement}}
  :store {:atomic [:wallet/debit :inventory/grant :receipt/write]
          :idempotency :receipt/id}
  :ranking {:partition [:board/game :board/season]
            :admission :score/verified}
  :social-graph {:friend-request [:pending :accepted :declined]
                 :block {:directional true :removes-friendship true}}
  :groups {:kinds #{:party :guild} :roles true :capacity true}
  :chat {:rooms #{:direct :party :guild :game}
         :admission [:membership :block :length :moderation :duplicate]
         :history :bounded}}
 :host-responsibilities
 #{:persistence :clock :identity-proof :score-verification
   :payment-verification :content-moderation :transport}}
